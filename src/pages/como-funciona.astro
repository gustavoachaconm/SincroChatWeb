---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Cómo funciona Sincro Chat',
  description: 'Cómo automatizar pedidos por WhatsApp con Sincro Chat para restaurantes y negocios',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'El cliente escribe a tu WhatsApp',
      text: 'El cliente contacta tu número como siempre. Sincro Chat entra en acción automáticamente.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'El sistema muestra el menú y guía el pedido',
      text: 'Sincro Chat despliega tu menú de forma interactiva y conduce al cliente paso a paso.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Validación automática de datos',
      text: 'El sistema verifica dirección, método de pago y detalles. Sin información incompleta.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Confirmación y entrega del pedido',
      text: 'El cliente recibe confirmación al instante. El pedido llega organizado a tu panel.',
    },
  ],
};

const flowSteps = [
  {
    number: '01',
    title: 'El cliente escribe a tu WhatsApp',
    description: 'Sin descargar nada, sin registrarse en ningún lado. El cliente usa el WhatsApp que ya tiene. Escribe al número de tu negocio y Sincro Chat responde de inmediato.',
    detail: 'Funciona con tu número de WhatsApp Business actual. No necesitas cambiar de número ni notificar a tus clientes.',
    color: 'primary',
  },
  {
    number: '02',
    title: 'Menú interactivo dentro del chat',
    description: 'Sincro Chat muestra tu menú de forma clara y navegable directamente en la conversación. El cliente selecciona productos, cantidades y variantes sin salir de WhatsApp.',
    detail: 'Tu menú se actualiza desde tu panel en tiempo real. Cambios de precio, disponibilidad o nuevos productos se reflejan al instante.',
    color: 'accent',
  },
  {
    number: '03',
    title: 'Guía paso a paso hasta completar el pedido',
    description: 'El sistema conduce al cliente por cada etapa: selección de productos, dirección de entrega, método de pago y confirmación. No hay forma de que el pedido quede incompleto.',
    detail: 'El flujo está diseñado para que ningún pedido quede incompleto. Cada paso es claro y no avanza sin la información necesaria.',
    color: 'primary',
  },
  {
    number: '04',
    title: 'Validación automática de datos',
    description: 'Antes de confirmar, el sistema verifica que la información esté completa: dirección válida, método de pago seleccionado, productos disponibles. Cero pedidos con datos incompletos.',
    detail: 'Los errores de pedido más comunes, como direcciones incompletas o productos agotados, se eliminan automáticamente.',
    color: 'accent',
  },
  {
    number: '05',
    title: 'Confirmación automática al cliente',
    description: 'El cliente recibe un resumen completo de su pedido con número de orden, tiempo estimado y detalles de entrega. Todo en WhatsApp, sin emails ni apps adicionales.',
    detail: 'El cliente recibe en el mismo chat el resumen completo: productos, dirección, método de pago y tiempo estimado de entrega.',
    color: 'primary',
  },
  {
    number: '06',
    title: 'Pedido organizado llega a tu panel',
    description: 'Tú recibes el pedido completo, estructurado y listo para preparar. Sin revisar conversaciones, sin transcribir datos a mano, sin errores de interpretación.',
    detail: 'Desde el panel puedes ver todos los pedidos activos, su estado y actualizar al cliente con un mensaje automático.',
    color: 'accent',
  },
] as const;

const capabilities = [
  {
    title: 'Múltiples conversaciones simultáneas',
    description: 'El sistema no se satura. Puede atender decenas o cientos de clientes al mismo tiempo sin perder ningún pedido.',
  },
  {
    title: 'Métricas y análisis de ventas',
    description: 'Ve cuáles son tus productos más pedidos, en qué horarios recibes más órdenes y cuánto estás vendiendo por período.',
  },
  {
    title: 'Personalización completa',
    description: 'Tu menú, tus precios, tus zonas de entrega, tus métodos de pago y el tono de los mensajes. Todo configurable.',
  },
  {
    title: 'Notificaciones de estado',
    description: 'Actualiza a tus clientes con mensajes automáticos cuando el pedido está en preparación, listo o en camino.',
  },
] as const;
---

<BaseLayout
  title="Cómo funciona Sincro Chat – Automatización de pedidos por WhatsApp"
  description="Descubre cómo Sincro Chat automatiza el flujo completo de pedidos por WhatsApp: menú interactivo, validación, confirmación y métricas. Para restaurantes y negocios."
  schema={schema}
>
  <Header />

  <main>

    <!-- ── Hero ── -->
    <section class="relative overflow-hidden py-14 md:py-20" style="background: linear-gradient(160deg, #f0fff8 0%, #ffffff 55%, #fff8f3 100%)">
      <div class="pointer-events-none absolute -top-20 -right-20 w-96 h-96 rounded-full opacity-25" style="background:var(--color-primary); filter:blur(100px)"></div>
      <div class="pointer-events-none absolute -bottom-16 -left-16 w-72 h-72 rounded-full opacity-15" style="background:var(--color-accent); filter:blur(90px)"></div>
      <div class="container relative text-center">
        <p class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6" style="background:var(--color-primary-light); color:var(--color-primary-dark)">
          El flujo completo de pedidos
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-[--color-text] max-w-3xl mx-auto leading-tight">
          De la conversación al pedido organizado, en automático
        </h1>
        <p class="mt-6 text-lg text-[--color-text-muted] max-w-2xl mx-auto leading-relaxed">
          Sincro Chat se integra a tu WhatsApp y gestiona todo el proceso de compra sin que tu equipo tenga que intervenir en cada mensaje.
        </p>
      </div>
    </section>

    <!-- ── Flujo paso a paso ── -->
    <section class="py-10 md:py-16" aria-labelledby="flujo-heading">
      <div class="container max-w-3xl">
        <h2 id="flujo-heading" class="text-3xl font-bold text-[--color-text] text-center mb-8">
          El flujo paso a paso
        </h2>
        <ol class="relative space-y-12">
          <!-- Línea vertical conectora -->
          <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-[--color-border] hidden md:block" aria-hidden="true"></div>

          {flowSteps.map(({ number, title, description, color }) => (
            <li class="relative flex gap-6 md:gap-8">
              <!-- Número -->
              <div
                class="relative z-10 w-12 h-12 rounded-full flex items-center justify-center font-black text-sm text-white shrink-0"
                style={`background:var(--color-${color})`}
                aria-hidden="true"
              >
                {number}
              </div>

              <!-- Contenido -->
              <div class="flex-1 pb-4">
                <h3 class="text-xl font-bold text-[--color-text] mb-2">{title}</h3>
                <p class="text-[--color-text-muted] leading-relaxed">{description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ── Capacidades adicionales ── -->
    <section class="py-10 md:py-16 bg-[--color-surface-alt]" aria-labelledby="capacidades-heading">
      <div class="container">
        <div class="text-center mb-8">
          <h2 id="capacidades-heading" class="text-3xl md:text-4xl font-bold text-[--color-text]">
            Y mucho más allá del pedido básico
          </h2>
          <p class="mt-4 text-[--color-text-muted] text-lg max-w-xl mx-auto">
            Sincro Chat no se detiene en tomar el pedido. Tiene todo lo que necesitas para escalar.
          </p>
        </div>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {capabilities.map(({ title, description }, i) => (
            <li class="flex gap-4 p-6 bg-white rounded-2xl border border-[--color-border] shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-200">
              <span class="mt-1 w-6 h-6 rounded-full flex items-center justify-center shrink-0 text-white text-xs font-bold" style={`background:var(--color-${i % 2 === 0 ? 'primary' : 'accent'})`}>✓</span>
              <div>
                <h3 class="font-bold text-[--color-text] mb-1">{title}</h3>
                <p class="text-sm text-[--color-text-muted] leading-relaxed">{description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="relative overflow-hidden py-14 md:py-16" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%)" aria-labelledby="cta-cf-heading">
      <div class="pointer-events-none absolute -top-12 -right-12 w-52 h-52 rounded-full border-2 border-white opacity-10"></div>
      <div class="pointer-events-none absolute -bottom-16 -left-16 w-64 h-64 rounded-full border-2 border-white opacity-10"></div>
      <div class="container relative text-center text-white">
        <h2 id="cta-cf-heading" class="text-3xl md:text-4xl font-bold mb-4">
          ¿Quieres ver esto en tu negocio?
        </h2>
        <p class="text-lg opacity-90 max-w-xl mx-auto mb-8">
          Habla con nuestro equipo. Te mostramos cómo quedaría el flujo configurado para tu tipo de negocio.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://wa.me/573155615323?text=Hola%2C+quiero+ver+c%C3%B3mo+funciona+Sincro+Chat+para+mi+negocio"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white font-semibold transition-opacity hover:opacity-90"
            style="color:var(--color-primary)"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Hablar con Ventas
          </a>
          <a
            href="/precios"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border-2 border-white/50 text-white font-semibold hover:border-white transition-colors"
          >
            Ver precios →
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
