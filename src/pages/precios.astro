---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { plans, comparison } from '../data/pricing';

const faqsPricing = [
  {
    question: '¿Hay contrato de permanencia?',
    answer: 'No. Puedes cambiar de plan o cancelar cuando quieras, sin penalidades.',
  },
  {
    question: '¿Cómo se cobra la comisión?',
    answer: 'La comisión se descuenta automáticamente de cada pedido procesado por Sincro Chat. Al final del período recibes un resumen detallado.',
  },
  {
    question: '¿Qué pasa si supero el límite de pedidos del plan Básico?',
    answer: 'Te notificamos antes de llegar al límite. Puedes hacer upgrade al plan Profesional en cualquier momento desde tu panel.',
  },
  {
    question: '¿Los precios incluyen impuestos?',
    answer: 'Los precios mostrados no incluyen IVA. El valor final depende de tu país de facturación.',
  },
] as const;
---

<BaseLayout
  title="Precios Sincro Chat – Comisiones justas para tu negocio"
  description="Planes y comisiones de Sincro Chat. Empieza gratis o escala con nuestro plan Profesional. Comisiones muy por debajo de los grandes marketplaces de delivery. Sin contratos ni permanencia."
>
  <Header />

  <!-- ── Banner: Página en construcción ── -->
  <div class="w-full py-4 text-center text-white text-sm font-semibold" style="background:var(--color-accent)">
    🚧 Estamos actualizando nuestros planes — próximamente nuevas opciones
  </div>

  <main class="relative">

    <!-- Overlay en construcción -->
    <div class="absolute inset-0 z-10 flex flex-col items-center justify-center text-center px-6 py-20"
      style="background: rgba(255,255,255,0.92); backdrop-filter: blur(6px)">
      <div class="max-w-md mx-auto">
        <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl" style="background:var(--color-primary-light)">
          🚧
        </div>
        <h2 class="text-3xl font-bold text-[--color-text] mb-4">Precios en construcción</h2>
        <p class="text-[--color-text-muted] leading-relaxed mb-8">
          Estamos reestructurando nuestros planes para ofrecerte opciones aún mejores.
          Vuelve pronto o contáctanos directamente para conocer las tarifas actuales.
        </p>
        <a
          href="https://wa.me/573155615323?text=Hola%2C+quiero+saber+los+precios+de+Sincro+Chat"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white font-semibold transition-opacity hover:opacity-90"
          style="background:var(--color-primary)"
        >
          Consultar precios por WhatsApp
        </a>
      </div>
    </div>

    <!-- ── Hero ── -->
    <section class="relative overflow-hidden py-14 md:py-20 text-center" style="background: linear-gradient(160deg, #f0fff8 0%, #ffffff 55%, #fff8f3 100%)">
      <div class="pointer-events-none absolute -top-20 -right-20 w-96 h-96 rounded-full opacity-25" style="background:var(--color-primary); filter:blur(100px)"></div>
      <div class="pointer-events-none absolute -bottom-16 -left-16 w-72 h-72 rounded-full opacity-15" style="background:var(--color-accent); filter:blur(90px)"></div>
      <div class="container relative">
        <p class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6" style="background:var(--color-primary-light); color:var(--color-primary-dark)">
          Planes y comisiones
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-[--color-text] max-w-2xl mx-auto leading-tight">
          Comisiones justas. Sin permanencia.
        </h1>
        <p class="mt-6 text-lg text-[--color-text-muted] max-w-xl mx-auto leading-relaxed">
          Los grandes marketplaces de delivery se quedan con el 25–30% de cada venta. Nosotros cobramos mucho menos y tú mantienes el control de tu negocio.
        </p>
      </div>
    </section>

    <!-- ── Planes ── -->
    <section class="py-10 md:py-16" aria-labelledby="planes-heading">
      <div class="container">
        <h2 id="planes-heading" class="sr-only">Planes de Sincro Chat</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
          {plans.map(({ name, description, price, priceSub, commission, highlight, cta, features, notIncluded }) => (
            <div class={[
              'flex flex-col rounded-2xl border p-8 transition-all duration-200',
              highlight
                ? 'border-[--color-primary] shadow-lg relative hover:-translate-y-1'
                : 'border-[--color-border] bg-white shadow-sm hover:-translate-y-1 hover:shadow-lg',
            ].join(' ')}
            style={highlight ? 'background: linear-gradient(to bottom, var(--color-primary-light), #fff); box-shadow: 0 0 0 2px var(--color-primary), 0 20px 50px rgba(0,190,99,0.15)' : ''}
            >
              {highlight && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full text-xs font-bold text-white" style="background:var(--color-accent)">
                  Más popular
                </span>
              )}

              <div class="mb-6">
                <h3 class="text-xl font-bold text-[--color-text]">{name}</h3>
                <p class="text-sm text-[--color-text-muted] mt-1">{description}</p>
              </div>

              <div class="mb-2">
                <span class="text-4xl font-black text-[--color-text]">{price}</span>
                <span class="text-sm text-[--color-text-muted] ml-1">{priceSub}</span>
              </div>
              <p class="text-sm font-semibold mb-6 pb-6 border-b border-[--color-border]" style="color:var(--color-primary)">
                + {commission}
              </p>

              <ul class="space-y-3 flex-1 mb-8">
                {features.map((feat) => (
                  <li class="flex items-start gap-2 text-sm text-[--color-text]">
                    <span class="mt-0.5 w-4 h-4 rounded-full flex items-center justify-center shrink-0 text-white text-[10px]" style="background:var(--color-primary)">✓</span>
                    {feat}
                  </li>
                ))}
                {notIncluded.map((feat) => (
                  <li class="flex items-start gap-2 text-sm text-[--color-text-muted] opacity-50">
                    <span class="mt-0.5 w-4 h-4 rounded-full flex items-center justify-center shrink-0 bg-gray-300 text-white text-[10px]" aria-hidden="true">✕</span>
                    {feat}
                  </li>
                ))}
              </ul>

              <a
                href="https://wa.me/573155615323?text=Hola%2C+quiero+saber+m%C3%A1s+del+plan+{name}"
                target="_blank"
                rel="noopener noreferrer"
                class={[
                  'w-full py-3 rounded-xl font-semibold text-center transition-opacity hover:opacity-90',
                  highlight ? 'text-white' : 'border-2 border-[--color-primary] text-[--color-primary] hover:bg-[--color-primary] hover:text-white',
                ].join(' ')}
                style={highlight ? 'background:var(--color-primary)' : ''}
              >
                {cta}
              </a>
            </div>
          ))}
        </div>
        <p class="text-center text-sm text-[--color-text-muted] mt-8">
          Precios en COP. No incluyen IVA. Sin contratos ni permanencia.
        </p>
      </div>
    </section>

    <!-- ── Comparación ── -->
    <section class="py-10 md:py-16 bg-[--color-surface-alt]" aria-labelledby="comparacion-heading">
      <div class="container max-w-3xl">
        <h2 id="comparacion-heading" class="text-3xl font-bold text-[--color-text] text-center mb-6">
          ¿Por qué Sincro Chat vs las alternativas?
        </h2>
        <div class="overflow-x-auto rounded-2xl border border-[--color-border] bg-white shadow-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[--color-border] bg-[--color-surface-alt]">
                <th class="text-left px-6 py-4 font-semibold text-[--color-text]">Plataforma</th>
                <th class="text-center px-6 py-4 font-semibold text-[--color-text]">Comisión</th>
                <th class="text-center px-6 py-4 font-semibold text-[--color-text]">Mensualidad</th>
                <th class="text-left px-6 py-4 font-semibold text-[--color-text] hidden sm:table-cell">Notas</th>
              </tr>
            </thead>
            <tbody>
              {comparison.map(({ label, commission, monthly, notes, highlight }) => (
                <tr class={[
                  'border-b border-[--color-border] last:border-0',
                  highlight ? 'font-semibold' : '',
                ].join(' ')}
                style={highlight ? 'background:var(--color-primary-light)' : ''}
                >
                  <td class="px-6 py-4 text-[--color-text] flex items-center gap-2">
                    {highlight && <span class="w-2 h-2 rounded-full inline-block" style="background:var(--color-primary)" aria-hidden="true"></span>}
                    {label}
                  </td>
                  <td class="px-6 py-4 text-center" style={highlight ? 'color:var(--color-primary)' : 'color:var(--color-text-muted)'}>{commission}</td>
                  <td class="px-6 py-4 text-center text-[--color-text-muted]">{monthly}</td>
                  <td class="px-6 py-4 text-[--color-text-muted] hidden sm:table-cell">{notes}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── FAQ Precios ── -->
    <section class="py-10 md:py-16" aria-labelledby="faq-precios-heading">
      <div class="container max-w-2xl">
        <h2 id="faq-precios-heading" class="text-3xl font-bold text-[--color-text] text-center mb-6">
          Preguntas sobre precios
        </h2>
        <dl class="space-y-4">
          {faqsPricing.map(({ question, answer }) => (
            <div class="border border-[--color-border] rounded-xl overflow-hidden bg-white">
              <dt>
                <button
                  type="button"
                  class="w-full flex items-center justify-between px-6 py-4 text-left font-semibold text-[--color-text] hover:bg-[--color-surface-alt] transition-colors faq-btn"
                  aria-expanded="false"
                >
                  <span>{question}</span>
                  <svg class="w-5 h-5 shrink-0 transition-transform faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </button>
              </dt>
              <dd class="hidden px-6 pb-4 text-[--color-text-muted] leading-relaxed faq-answer">
                {answer}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="relative overflow-hidden py-14 md:py-16" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%)" aria-labelledby="cta-precios-heading">
      <div class="pointer-events-none absolute -top-12 -right-12 w-52 h-52 rounded-full border-2 border-white opacity-10"></div>
      <div class="pointer-events-none absolute -bottom-16 -left-16 w-64 h-64 rounded-full border-2 border-white opacity-10"></div>
      <div class="container relative text-center text-white">
        <h2 id="cta-precios-heading" class="text-3xl font-bold mb-4">¿Tienes dudas sobre qué plan elegir?</h2>
        <p class="text-lg opacity-90 max-w-md mx-auto mb-8">
          Cuéntanos cómo funciona tu negocio y te recomendamos el plan ideal.
        </p>
        <a
          href="https://wa.me/573155615323?text=Hola%2C+quiero+saber+qu%C3%A9+plan+es+mejor+para+mi+negocio"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white font-semibold transition-opacity hover:opacity-90"
          style="color:var(--color-primary)"
        >
          Hablar con Ventas
        </a>
      </div>
    </section>

  </main> <!-- fin relative -->

  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const answer = btn.closest('div')?.querySelector<HTMLElement>('.faq-answer');
      const icon = btn.querySelector<SVGElement>('.faq-icon');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      answer?.classList.toggle('hidden', isOpen);
      icon?.classList.toggle('rotate-180', !isOpen);
    });
  });
</script>
